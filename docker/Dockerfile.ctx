FROM golang:1.23-alpine AS builder

RUN apk add --no-cache gcc musl-dev

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=1 go build -o /bin/ctx ./cmd/ctx

FROM alpine:3.20
RUN apk add --no-cache ca-certificates
COPY --from=builder /bin/ctx /usr/local/bin/ctx
ENTRYPOINT ["ctx"]
