# Required: shared API key for the Contexo server (rotate away from "dev-key" before deploy).
# Legacy auth path — kept while the CLI and dashboard migrate to user accounts.
CONTEXO_API_KEY=change-me-to-a-real-secret

# Recommended (Phase 3+): persistent secret for signing user session JWTs.
# Generate with: openssl rand -hex 32
# Leave unset to use an ephemeral per-boot secret (existing sessions invalidate on restart).
# CONTEXO_SESSION_SECRET=

# Optional (Phase 3+): Google OAuth 2.0 Client ID used to verify ID tokens from the dashboard.
# Create at https://console.cloud.google.com/apis/credentials
# GOOGLE_OAUTH_CLIENT_ID=

# Optional: dashboard origins allowed by CORS (comma-separated).
# Defaults to http://localhost:5173, http://localhost:3000 when unset.
# CONTEXO_CORS_ORIGINS=https://dash.yourdomain.com,http://localhost:5173

# Optional: host port to expose (defaults to 8080).
# CTXHUB_PORT=8080
